MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://sepolia.gateway.tenderly.co
PRIVATE_KEY=0xYOUR_DEPLOYER_KEY_FOR_E2E_ESCROW
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_REASONING_EFFORT=low
# Local/OpenAI-compatible fallback when OPENAI_API_KEY is unset:
# LLM_BASE_URL=http://localhost:18001/v1
# LLM_MODEL=gpt-oss-120b
LLM_RESPONSE_CACHE=1
LLM_RESPONSE_CACHE_DIR=cache/llm-responses
LLM_RESPONSE_CACHE_DB_PATH=cache/llm-responses/responses.sqlite
LLM_RESPONSE_CACHE_TTL_SECONDS=0
LLM_RESPONSE_CACHE_MAX_ENTRIES=4096
LLM_RESPONSE_CACHE_MIN_CONFIRMATIONS=2
LLM_RESPONSE_CACHE_FINALITY_WAIT_TIMEOUT_MS=180000
LLM_RESPONSE_CACHE_FINALITY_POLL_MS=2000
LLM_RESPONSE_CACHE_LOG=1
PRICE_OVERRIDES_JSON={"0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48":"1","0xdAC17F958D2ee523a2206206994597C13D831ec7":"1"}
